# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=TontiTOGO
APP_ENV=production
APP_KEY=                          # généré par: php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-app.onrender.com
APP_TIMEZONE=Africa/Lome
FRONTEND_URL=https://your-frontend.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# ── Base de données (Supabase PostgreSQL) ────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=aws-0-eu-west-1.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.VOTRE_PROJECT_REF
DB_PASSWORD=VOTRE_MOT_DE_PASSE_SUPABASE
DB_SCHEMA=tontitogo
DB_SSLMODE=require

# ── Sessions / Cache ─────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ── Mail (Mailgun ou autre en prod) ─────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@tontitogo.tg"
MAIL_FROM_NAME="TontiTOGO"

# ── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_VERIFY_SSL=true

# ── NGH Corp SMS ─────────────────────────────────────────────────────────────
NGHCORP_API_KEY=
NGHCORP_API_SECRET=
NGHCORP_SENDER_ID=TontiTOGO
NGHCORP_BASE_URL=https://extranet.nghcorp.net
NGHCORP_VERIFY_SSL=true

# ── Swagger ──────────────────────────────────────────────────────────────────
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_CONST_HOST=https://your-app.onrender.com
L5_FORMAT_TO_USE_FOR_DOCS=json
